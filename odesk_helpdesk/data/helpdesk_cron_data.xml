<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Auto-close resolved tickets -->
        <record id="ir_cron_auto_close_tickets" model="ir.cron">
            <field name="name">Helpdesk: Auto-close Resolved Tickets</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_close_tickets()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- SLA escalation check -->
        <record id="ir_cron_sla_escalation" model="ir.cron">
            <field name="name">Helpdesk: SLA Escalation Check</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="state">code</field>
            <field name="code">model._cron_sla_escalation()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Ticket creation confirmation -->
        <record id="mail_template_ticket_created" model="mail.template">
            <field name="name">Helpdesk: Ticket Created</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="subject">Ticket {{ object.number }} - {{ object.name }}</field>
            <field name="email_from">{{ (object.team_id.leader_id.email_formatted or object.company_id.email_formatted or 'noreply@example.com') }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p>Dear {{ object.partner_id.name }},</p>
    <p>Your support ticket has been created successfully.</p>
    <ul>
        <li><strong>Ticket Number:</strong> {{ object.number }}</li>
        <li><strong>Subject:</strong> {{ object.name }}</li>
        <li><strong>Category:</strong> {{ object.category_id.name }}</li>
        <li><strong>Priority:</strong> {{ object.priority }}</li>
        <li><strong>Team:</strong> {{ object.team_id.name }}</li>
    </ul>
    <p>We will get back to you as soon as possible.</p>
    <p>Best regards,<br/>IT Helpdesk</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Agent assigned notification -->
        <record id="mail_template_ticket_assigned" model="mail.template">
            <field name="name">Helpdesk: Ticket Assigned</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="subject">Ticket {{ object.number }} assigned to you</field>
            <field name="email_from">{{ (object.company_id.email_formatted or 'noreply@example.com') }}</field>
            <field name="email_to">{{ object.user_id.email }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p>Dear {{ object.user_id.name }},</p>
    <p>Ticket <strong>{{ object.number }}</strong> has been assigned to you.</p>
    <ul>
        <li><strong>Subject:</strong> {{ object.name }}</li>
        <li><strong>Category:</strong> {{ object.category_id.name }}</li>
        <li><strong>Priority:</strong> {{ object.priority }}</li>
        <li><strong>Submitter:</strong> {{ object.partner_id.name }}</li>
    </ul>
    <p>Please review and respond promptly.</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Stage change notification -->
        <record id="mail_template_ticket_stage_changed" model="mail.template">
            <field name="name">Helpdesk: Stage Changed</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="subject">Ticket {{ object.number }} - Status Update</field>
            <field name="email_from">{{ (object.company_id.email_formatted or 'noreply@example.com') }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p>Dear {{ object.partner_id.name }},</p>
    <p>Your ticket <strong>{{ object.number }}</strong> status has been updated.</p>
    <ul>
        <li><strong>Subject:</strong> {{ object.name }}</li>
        <li><strong>New Status:</strong> {{ object.stage_id.name }}</li>
    </ul>
    <p>Best regards,<br/>IT Helpdesk</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- SLA escalation warning -->
        <record id="mail_template_sla_escalation" model="mail.template">
            <field name="name">Helpdesk: SLA Escalation Warning</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="subject">SLA Warning: Ticket {{ object.number }} approaching deadline</field>
            <field name="email_from">{{ (object.company_id.email_formatted or 'noreply@example.com') }}</field>
            <field name="email_to">{{ (object.user_id.email or '') }},{{ (object.team_id.leader_id.email or '') }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p><strong>SLA Escalation Warning</strong></p>
    <p>Ticket <strong>{{ object.number }}</strong> is approaching its SLA deadline.</p>
    <ul>
        <li><strong>Subject:</strong> {{ object.name }}</li>
        <li><strong>SLA Deadline:</strong> {{ object.sla_deadline }}</li>
        <li><strong>Assigned To:</strong> {{ object.user_id.name or 'Unassigned' }}</li>
        <li><strong>Team:</strong> {{ object.team_id.name }}</li>
    </ul>
    <p>Please take immediate action.</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_team_view_form" model="ir.ui.view">
        <field name="name">helpdesk.team.form</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <form string="Helpdesk Team">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Team Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="leader_id"/>
                            <field name="assignment_method"/>
                            <field name="auto_close_days"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="color" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Categories">
                            <field name="category_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="SLA Policies">
                            <field name="sla_policy_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="priority"/>
                                    <field name="time_response"/>
                                    <field name="time_resolution"/>
                                    <field name="stage_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group>
                        <field name="description" placeholder="Team description..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="helpdesk_team_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.team.tree</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <list string="Helpdesk Teams">
                <field name="name"/>
                <field name="leader_id"/>
                <field name="assignment_method"/>
                <field name="auto_close_days"/>
            </list>
        </field>
    </record>

    <record id="helpdesk_team_action" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">helpdesk.team</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

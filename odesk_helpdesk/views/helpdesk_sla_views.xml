<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_sla_policy_view_form" model="ir.ui.view">
        <field name="name">helpdesk.sla.policy.form</field>
        <field name="model">helpdesk.sla.policy</field>
        <field name="arch" type="xml">
            <form string="SLA Policy">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="team_id"/>
                            <field name="priority"/>
                        </group>
                        <group>
                            <field name="stage_id"/>
                            <field name="time_response" widget="float_time"/>
                            <field name="time_resolution" widget="float_time"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Categories">
                        <field name="category_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="helpdesk_sla_policy_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.sla.policy.tree</field>
        <field name="model">helpdesk.sla.policy</field>
        <field name="arch" type="xml">
            <list string="SLA Policies">
                <field name="name"/>
                <field name="team_id"/>
                <field name="priority"/>
                <field name="time_response"/>
                <field name="time_resolution"/>
                <field name="stage_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="helpdesk_sla_policy_action" model="ir.actions.act_window">
        <field name="name">SLA Policies</field>
        <field name="res_model">helpdesk.sla.policy</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
